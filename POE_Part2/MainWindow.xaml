<Window x:Class="POE_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard Bot" 
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        MinHeight="400" MinWidth="600">

    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#6C63FF">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🛡️ CyberGuard Bot" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Cybersecurity Awareness Assistant" 
                           FontSize="11" 
                           Foreground="#E0DDFF" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- CHAT DISPLAY - ListBox (fixed) -->
        <ListBox x:Name="ChatDisplay" 
                 Grid.Row="1"
                 Background="#2D2D3D" 
                 Foreground="White" 
                 FontSize="13" 
                 Margin="10" 
                 BorderBrush="#6C63FF" 
                 BorderThickness="1"/>

        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="#3D3D4D">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputTextBox" 
                         Grid.Column="0"
                         Background="#4D4D5D" 
                         Foreground="White"
                         Padding="10"
                         Margin="0,0,10,0"
                         BorderBrush="#6C63FF" 
                         BorderThickness="1"
                         KeyDown="UserInputTextBox_KeyDown"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="Send"
                        Width="60" 
                        Height="35"
                        Background="#6C63FF" 
                        Foreground="White"
                        FontWeight="Bold"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>